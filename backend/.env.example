# Copy this to .env and fill in the values `supabase start` prints out
# (run it from the repo root, not from backend/).

# The "API URL" line from `supabase start` output.
LOCAL_SUPABASE_URL=http://127.0.0.1:54321

# The "anon key" line from `supabase start` output.
LOCAL_SUPABASE_PUBKEY=

# Only needed for the produce/meat photo-identification feature (phase 2).
# Not required to test barcode scanning via Open Food Facts.
GEMINI_API_KEY=
